# PostgreSQL connection (e.g. Supabase, Neon, or any Postgres).
# DATABASE_URL uses the pooled connection; DIRECT_URL is used for migrations.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Public base used when building short links (no trailing slash).
NEXT_PUBLIC_BASE_URL="http://localhost:3008"
